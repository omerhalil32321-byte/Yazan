const defaultStore = {
    "name": "خدمة التوصيل من ساعة 10:00صباح حتا الساعة 12:00مساءا",
    "desc": "أشهى المأكولات - توصيل سريع",
    "whatsapp": "963981738986",
    "headerImage": "data:image/jpeg;base64,

/* ======= حالة التطبيق ======= */
let products = [];
let storeSettings = {};
let cart = [];
let currentCategory = 'all';
let currentImageBase64 = null;
let currentHeaderImageBase64 = null;

/* ======= تهيئة ======= */
function init(){
  loadData();
  renderStore();
  renderAdminProducts();
  updateCartUI();

  // event listeners that require DOM nodes
  document.getElementById('passwordEnterBtn').addEventListener('click', checkPassword);
  document.getElementById('passwordInput').addEventListener('keypress', function(e){ if(e.key==='Enter') checkPassword(); });
}
function loadData(){
  // لا نحذف أي شيء من localStorage لكي لا تُفقد البيانات
  products = JSON.parse(JSON.stringify(defaultProducts));
  storeSettings = JSON.parse(JSON.stringify(defaultStore));
  const savedCart = localStorage.getItem('shop_cart_v1');
  cart = savedCart ? JSON.parse(savedCart) : [];
  updateStoreDisplay();
  if(storeSettings.headerImage) applyHeaderImage(storeSettings.headerImage);
}

/* ======= واجهة المتجر ======= */
function updateStoreDisplay(){
  document.getElementById('storeName').textContent = storeSettings.name;
  document.getElementById('storeDesc').textContent = storeSettings.desc;
  document.getElementById('whatsappText').textContent = '+' + storeSettings.whatsapp;
  document.getElementById('adminStoreName').value = storeSettings.name;
  document.getElementById('adminStoreDesc').value = storeSettings.desc;
  document.getElementById('adminWhatsapp').value = storeSettings.whatsapp;
}

function renderStore(){
  const container = document.getElementById('productsContainer');
  const filtered = currentCategory==='all' ? products : products.filter(p=>p.category===currentCategory);
  if(filtered.length===0){ container.innerHTML = '<div style="padding:30px;text-align:center;color:#999">لا توجد منتجات</div>'; return; }
  container.innerHTML = filtered.map(p=>`
    <div class="product-card">
      <img src="${p.image}" alt="${p.name}" onerror="this.src='https://via.placeholder.com/400x300/e74c3c/ffffff?text=لا+صورة'">
      <div class="product-info">
        <div style="font-weight:bold;margin-bottom:6px">${p.name}</div>
        <div style="color:#666;font-size:13px;margin-bottom:8px">${p.desc||''}</div>
        <div style="font-weight:bold;color:#e74c3c">${p.price.toLocaleString()} ل.س</div>
      </div>
      <button class="add-cart-btn" onclick="addToCart(${p.id})">🛒 أضف للسلة</button>
    </div>
  `).join('');
}

/* ======= الفلترة ======= */
function filterCategory(cat, ev){
  currentCategory = cat;
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  if(ev && ev.currentTarget) ev.currentTarget.classList.add('active');
  renderStore();
}

/* ======= السلة ======= */
function saveCartData(){ localStorage.setItem('shop_cart_v1', JSON.stringify(cart)); }
function addToCart(id){
  const p = products.find(x=>x.id==id); if(!p) return;
  const item = cart.find(i=>i.id==id);
  if(item) item.qty++;
  else cart.push({id:p.id,name:p.name,price:p.price,image:p.image,qty:1});
  saveCartData(); updateCartUI(); showToast('✅ أضيف للسلّة: '+p.name);
}
function changeQty(id, delta){
  const it = cart.find(i=>i.id==id); if(!it) return;
  it.qty += delta;
  if(it.qty<=0) cart = cart.filter(i=>i.id!=id);
  saveCartData(); renderCartModal(); updateCartUI();
}
function removeFromCart(id){
  cart = cart.filter(i=>i.id!=id); saveCartData(); renderCartModal(); updateCartUI(); showToast('🗑️ تمت إزالة المنتج');
}
function updateCartUI(){
  const totalItems = cart.reduce((s,i)=>s+i.qty,0);
  const totalPrice = cart.reduce((s,i)=>s+i.qty*i.price,0);
  document.getElementById('cartCount').textContent = totalItems;
  document.getElementById('cartTotal').textContent = totalPrice.toLocaleString() + ' ل.س';
  document.getElementById('cartBar').style.display = totalItems>0 ? 'flex' : 'none';
}
function openCartModal(){ renderCartModal(); document.getElementById('cartModal').style.display = 'flex'; }
function closeCartModal(){ document.getElementById('cartModal').style.display = 'none'; }

function renderCartModal(){
  const container = document.getElementById('cartItems');
  const summary = document.getElementById('cartSummary');
  if(cart.length===0){
    container.innerHTML = '<div style="padding:30px;text-align:center;color:#999">السلة فارغة</div>';
    summary.innerHTML = ''; return;
  }
  container.innerHTML = cart.map(i=>`
    <div class="cart-item">
      <img src="${i.image}" onerror="this.src='https://via.placeholder.com/60/e74c3c/ffffff?text=?'">
      <div style="flex:1;text-align:right">
        <div style="font-weight:bold">${i.name}</div>
        <div style="color:#e74c3c">${(i.price*i.qty).toLocaleString()} ل.س</div>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;align-items:center">
        <div style="display:flex;gap:6px">
          <button class="qty-btn" onclick="changeQty(${i.id},-1)">−</button>
          <div style="min-width:26px;text-align:center;font-weight:bold">${i.qty}</div>
          <button class="qty-btn" onclick="changeQty(${i.id},1)">+</button>
        </div>
        <button style="background:#e74c3c;color:#fff;padding:6px;border-radius:6px;border:0;cursor:pointer" onclick="removeFromCart(${i.id})">حذف</button>
      </div>
    </div>
  `).join('');
  const subtotal = cart.reduce((s,i)=>s+i.qty*i.price,0);
  summary.innerHTML = `<div style="text-align:right">
    <div style="margin-bottom:6px">المجموع: <strong>${subtotal.toLocaleString()} ل.س</strong></div>
    <div style="margin-bottom:6px">التوصيل: <strong>مجاني</strong></div>
    <div style="font-size:18px;font-weight:bold;color:#e74c3c">الإجمالي: ${subtotal.toLocaleString()} ل.س</div>
  </div>`;
}

/* ======= إرسال الطلب عبر واتساب ======= */
function sendCartOrder(){
  if(cart.length===0){ showToast('السلة فارغة'); return; }
  const note = document.getElementById('cartNote').value.trim();
  const phone = storeSettings.whatsapp;
  let message = `🛒 *طلب جديد من ${storeSettings.name}*%0A%0A`;
  message += `📋 *المنتجات:*%0A`;
  let total = 0;
  cart.forEach((item,idx)=>{
    const line = item.price*item.qty;
    total += line;
    message += `${idx+1}. ${item.name} × ${item.qty} = ${line.toLocaleString()} ل.س%0A`;
  });
  message += `%0A💰 *الإجمالي: ${total.toLocaleString()} ل.س*%0A`;
  if(note) message += `%0A📝 *ملاحظة:* ${note}%0A`;
  message += `%0A⏰ ${new Date().toLocaleString('ar-SY')}`;
  window.open(`https://wa.me/${phone}?text=${message}`,'_blank');
  cart = []; saveCartData(); updateCartUI(); closeCartModal(); showToast('📱 تم فتح الواتساب لإرسال الطلب!');
}

/* ======= صورة الهيدر ======= */
function previewHeaderImage(input){
  if(input.files && input.files[0]){
    const file = input.files[0];
    const reader = new FileReader();
    reader.onload = function(e){
      currentHeaderImageBase64 = e.target.result;
      const img = document.getElementById('headerImagePreview');
      img.src = currentHeaderImageBase64;
      img.style.display = 'block';
    };
    reader.readAsDataURL(file);
  }
}
function applyHeaderImage(base64){
  const header = document.getElementById('storeHeader');
  if(base64){
    header.style.backgroundImage = 'url('+base64+')';
    header.style.backgroundColor = 'transparent';
  } else {
    header.style.backgroundImage = 'none';
    header.style.backgroundColor = '#e74c3c';
  }
}
function saveHeaderImage(){
  if(currentHeaderImageBase64){
    storeSettings.headerImage = currentHeaderImageBase64;
    applyHeaderImage(currentHeaderImageBase64);
    showToast('✅ تم حفظ صورة الهيدر في الإعدادات');
  } else {
    showToast('⚠️ اختر صورة أولاً');
  }
}
function removeHeaderImage(){
  storeSettings.headerImage = '';
  currentHeaderImageBase64 = null;
  document.getElementById('headerImageFile').value = '';
  document.getElementById('headerImagePreview').style.display = 'none';
  applyHeaderImage(null);
  showToast('🗑️ تمت إزالة صورة الهيدر');
}

/* ======= إدارة المنتجات (صورة من المعرض) ======= */
function previewImageFile(input){
  if(input.files && input.files[0]){
    const file = input.files[0];
    const reader = new FileReader();
    reader.onload = function(e){
      currentImageBase64 = e.target.result;
      const img = document.getElementById('imagePreview');
      img.src = currentImageBase64;
      img.style.display = 'block';
    };
    // قراءة بصيغة DataURL
    reader.readAsDataURL(file);
  }
}

function saveProduct(){
  const name = document.getElementById('productName').value.trim();
  const desc = document.getElementById('productDesc').value.trim();
  const price = parseInt(document.getElementById('productPrice').value) || 0;
  const category = document.getElementById('productCategory').value;
  const editId = document.getElementById('editProductId').value;
  if(!name || !price){ alert('ادخل اسم وسعر المنتج'); return; }
  let image = currentImageBase64;
  if(editId){
    const idx = products.findIndex(p=>p.id==editId);
    if(idx!==-1){
      if(!image) image = products[idx].image;
      products[idx] = {...products[idx], name, desc, price, category, image};
    }
  } else {
    if(!image) image = 'https://via.placeholder.com/400x300/e74c3c/ffffff?text='+encodeURIComponent(name);
    const newId = products.length ? Math.max(...products.map(p=>p.id))+1 : 1;
    products.push({id:newId,name,desc,price,category,image});
  }
  // تنظيف نموذج
  document.getElementById('productName').value='';document.getElementById('productDesc').value='';document.getElementById('productPrice').value='';document.getElementById('editProductId').value='';document.getElementById('productImageFile').value='';document.getElementById('imagePreview').style.display='none';
  currentImageBase64 = null;
  renderAdminProducts(); renderStore(); showToast('✅ تم حفظ المنتج محلياً');
}

function editProduct(id){
  const p = products.find(x=>x.id==id); if(!p) return;
  document.getElementById('productName').value = p.name; document.getElementById('productDesc').value = p.desc||''; document.getElementById('productPrice').value = p.price; document.getElementById('productCategory').value = p.category; document.getElementById('editProductId').value = p.id;
  if(p.image && p.image.startsWith('data:')){ currentImageBase64 = p.image; document.getElementById('imagePreview').src = p.image; document.getElementById('imagePreview').style.display='block'; } else { currentImageBase64 = null; document.getElementById('imagePreview').style.display='none'; }
  window.scrollTo(0,150);
}

function deleteProduct(id){
  if(!confirm('تأكيد حذف المنتج؟')) return;
  products = products.filter(p=>p.id!=id); renderAdminProducts(); renderStore(); showToast('🗑️ حُذف المنتج');
}

function renderAdminProducts(){
  const container = document.getElementById('adminProductsList');
  if(products.length===0){ container.innerHTML = '<p style="text-align:center;color:#999">لا توجد منتجات</p>'; return; }
  container.innerHTML = products.map(p=>`
    <div style="display:flex;align-items:center;gap:10px;padding:8px;border-bottom:1px solid #eee">
      <img src="${p.image}" style="width:56px;height:56px;border-radius:8px;object-fit:cover" onerror="this.src='https://via.placeholder.com/60/e74c3c/ffffff?text=?'">
      <div style="flex:1;text-align:right">
        <div style="font-weight:bold">${p.name}</div>
        <div style="color:#e74c3c">${p.price.toLocaleString()} ل.س</div>
      </div>
      <div style="display:flex;gap:6px">
        <button onclick="editProduct(${p.id})" style="background:#f39c12;color:#fff;border:0;padding:6px;border-radius:6px;cursor:pointer">تعديل</button>
        <button onclick="deleteProduct(${p.id})" style="background:#e74c3c;color:#fff;border:0;padding:6px;border-radius:6px;cursor:pointer">حذف</button>
      </div>
    </div>
  `).join('');
}

/* ======= إعداد المتجر ======= */
function saveStoreSettings(){ storeSettings.name = document.getElementById('adminStoreName').value.trim() || storeSettings.name; storeSettings.desc = document.getElementById('adminStoreDesc').value.trim() || storeSettings.desc; storeSettings.whatsapp = document.getElementById('adminWhatsapp').value.replace(/[^0-9]/g,'') || storeSettings.whatsapp; updateStoreDisplay(); showToast('✅ تم تحديث الإعدادات مؤقتاً'); }

/* ======= حماية الدخول ======= */
function showStore(){
  document.getElementById('storeView').style.display = 'block';
  document.getElementById('adminPanel').style.display = 'none';
}
function showAdmin(){ document.getElementById('passwordInput').value=''; document.getElementById('passwordError').style.display='none'; document.getElementById('passwordModal').style.display='flex'; setTimeout(()=>document.getElementById('passwordInput').focus(),120); }
function checkPassword(){ const v = document.getElementById('passwordInput').value; if(v===ADMIN_PASSWORD){ document.getElementById('passwordModal').style.display='none'; document.getElementById('storeView').style.display='none'; document.getElementById('adminPanel').style.display='block'; renderAdminProducts(); } else { document.getElementById('passwordError').style.display='block'; } }
function closePasswordModal(){ document.getElementById('passwordModal').style.display='none'; }

/* ======= حفظ إلى GitHub (تفاصيل وتصحيح) ======= */
async function startSaveToGitHub(){
  try{
    showSavingModal(true,'جاري تجهيز الكود...');
    const productsJSON = JSON.stringify(products, null, 4);
    const storeJSON = JSON.stringify(storeSettings, null, 4);

    // جلب الصفحة الحالية كنص
    const pageHtml = await fetch(window.location.href, {cache:'no-store'}).then(r=>r.text());
    // استبدال الكتل المعرفة للبيانات
    let updatedHtml = pageHtml.replace(/const defaultProducts = \[[\s\S]*?\];/, `const defaultProducts = ${productsJSON};`);
    updatedHtml = updatedHtml.replace(/const defaultStore = \{[\s\S]*?\};/, `const defaultStore = ${storeJSON};`);

    // البيانات المطلوبة من المستخدم
    const owner = prompt('ادخل owner (اسم الحساب أو المنظمة على GitHub):', localStorage.getItem('gh_owner')||'');
    if(owner===null){ showSavingModal(false); showToast('⛔ تم الإلغاء'); return; }
    const repo = prompt('ادخل repo (اسم المستودع):', localStorage.getItem('gh_repo')||'');
    if(repo===null){ showSavingModal(false); showToast('⛔ تم الإلغاء'); return; }
    const path = prompt('ادخل مسار الملف داخل المستودع (مثل index.html):', localStorage.getItem('gh_path')||'index.html');
    if(path===null){ showSavingModal(false); showToast('⛔ تم الإلغاء'); return; }
    const message = prompt('ادخل رسالة الـ commit:', 'Update store content from admin panel');
    if(message===null){ showSavingModal(false); showToast('⛔ تم الإلغاء'); return; }
    const branch = prompt('اسم الفرع (branch) لحفظ التغييرات، اتركه فارغاً للحفظ على الفرع الافتراضي:', localStorage.getItem('gh_branch')||'') || null;

    // حفظ تفضيلات غير حساسة
    localStorage.setItem('gh_owner', owner); localStorage.setItem('gh_repo', repo); localStorage.setItem('gh_path', path);
    if(branch) localStorage.setItem('gh_branch', branch);

    // PAT مؤقت في sessionStorage
    let token = sessionStorage.getItem('gh_token') || '';
    if(!token){
      token = prompt('أدخل Personal Access Token (PAT) بصلاحية repo (سيُخزن مؤقتاً في هذه الجلسة فقط):');
      if(!token){ showSavingModal(false); showToast('⛔ تم الإلغاء'); return; }
      sessionStorage.setItem('gh_token', token);
    }

    showSavingModal(true,'جاري حفظ الملف على GitHub...');

    const apiBase = 'https://api.github.com';
    const safePath = encodeURIComponent(path).replace(/%2F/g, '/');
    const fileUrl = `${apiBase}/repos/${encodeURIComponent(owner)}/${encodeURIComponent(repo)}/contents/${safePath}`;
    const headers = {'Authorization':'Bearer '+token,'Accept':'application/vnd.github+json'};

    console.info('DEBUG: GET', fileUrl, branch ? ('branch=' + branch) : '(default branch)');
    const getUrl = branch ? (fileUrl + '?ref=' + encodeURIComponent(branch)) : fileUrl;
    let getResp = await fetch(getUrl, {headers});
    console.info('DEBUG GET status', getResp.status);
    const getText = await getResp.text();
    let getJson = null;
    try { getJson = JSON.parse(getText); } catch(e){ getJson = getText; }
    console.debug('DEBUG GET response', getJson);

    let sha = null;
    if(getResp.status === 200){
      sha = getJson.sha;
    } else if(getResp.status === 404){
      sha = null;
    } else {
      if(getResp.status === 401 || getResp.status === 403) sessionStorage.removeItem('gh_token');
      showSavingModal(false);
      alert('فشل التحقق من الملف على GitHub: ' + getResp.status + '\n' + (typeof getJson === 'string' ? getJson : JSON.stringify(getJson, null, 2)));
      return;
    }

    const putBody = {
      message: message,
      content: btoa(unescape(encodeURIComponent(updatedHtml))),
      committer: { name: 'site-admin', email: 'admin@example.com' }
    };
    if(sha) putBody.sha = sha;
    if(branch) putBody.branch = branch;

    console.info('DEBUG: PUT', fileUrl, { sha: sha, branch: branch });
    const putResp = await fetch(fileUrl, {
      method: 'PUT',
      headers: { ...headers, 'Content-Type': 'application/json' },
      body: JSON.stringify(putBody)
    });

    console.info('DEBUG PUT status', putResp.status);
    const putText = await putResp.text();
    let putJson = null;
    try { putJson = JSON.parse(putText); } catch(e){ putJson = putText; }
    console.debug('DEBUG PUT response', putJson);

    if(!putResp.ok){
      if(putResp.status === 401 || putResp.status === 403) sessionStorage.removeItem('gh_token');
      showSavingModal(false);
      alert('فشل الحفظ على GitHub: ' + putResp.status + '\n' + (typeof putJson === 'string' ? putJson : JSON.stringify(putJson, null, 2)));
      return;
    }

    showSavingModal(false);
    showToast('✅ تم الحفظ في المستودع بنجاح!');
    console.log('Commit response:', putJson);
    const commitUrl = putJson && putJson.commit && putJson.commit.html_url ? putJson.commit.html_url : null;
    if(commitUrl){
      if(confirm('فتح صفحة commit على GitHub؟')) window.open(commitUrl, '_blank');
    } else {
      alert('تم الحفظ بنجاح، ولكن لم يعُد رابط commit في الرد. تفقد الريبو والفرع الذي اخترته.');
    }
  }catch(err){
    console.error('Save error', err);
    showSavingModal(false);
    alert('حدث خطأ أثناء الحفظ: ' + (err && err.message ? err.message : err));
  }
}

function showSavingModal(show, text){
  const m = document.getElementById('savingModal'); const c = document.getElementById('savingContent');
  if(show){ c.innerHTML = `<p>${text||'جارٍ...'}</p>`; m.style.display='flex'; } else m.style.display='none';
}

/* ======= مساعدة وعرض رسائل ======= */
function showToast(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.style.display='block'; setTimeout(()=>t.style.display='none',3000); }

/* ======= بدء ======= */
window.addEventListener('load', init);
</script>

</body>
  </html>
